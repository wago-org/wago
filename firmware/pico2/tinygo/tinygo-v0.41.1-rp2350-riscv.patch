+//go:build rp2350 && pico2riscv
+
+package interrupt
+
+import "device/riscv"
+
+//go:linkname callHandlers runtime/interrupt.callHandlers
+func callHandlers(num int)
+
+const (
+	hazard3MEIEA      = riscv.CSR(0xbe0)
+	hazard3MEIFA      = riscv.CSR(0xbe2)
+	hazard3MEIPRA     = riscv.CSR(0xbe3)
+	hazard3MEINEXT    = riscv.CSR(0xbe4)
+	hazard3MEICONTEXT = riscv.CSR(0xbe5)
+)
+
+func hazard3ArrayBits(num, entriesPerWindow int) (window, mask uintptr) {
+	window = uintptr(num / entriesPerWindow)
+	mask = uintptr(1) << (num % entriesPerWindow)
+	return
+}
+
+// Enable enables this external interrupt on the executing Hazard3 core.
+func (irq Interrupt) Enable() {
+	window, mask := hazard3ArrayBits(irq.num, 16)
+	selectorAndMask := window | mask<<16
+	hazard3MEIFA.ClearBits(selectorAndMask)
+	hazard3MEIEA.SetBits(selectorAndMask)
+}
+
+// Disable disables this external interrupt on the executing Hazard3 core.
+func (irq Interrupt) Disable() {
+	window, mask := hazard3ArrayBits(irq.num, 16)
+	hazard3MEIEA.ClearBits(window | mask<<16)
+}
+
+// SetPriority maps the Cortex-style TinyGo priority (zero is highest) onto
+// Hazard3's four-bit priority field (15 is highest).
+func (irq Interrupt) SetPriority(priority uint8) {
+	window := uintptr(irq.num / 4)
+	shift := uintptr(irq.num%4) * 4
+	mask := uintptr(0xf) << shift
+	value := uintptr((priority>>4)^0xf) << shift
+	hazard3MEIPRA.ClearBits(window | mask<<16)
+	hazard3MEIPRA.SetBits(window | value<<16)
+}
+
+func callHandler(num int) {
+	switch num {
+	case 0:
+		callHandlers(0)
+	case 1:
+		callHandlers(1)
+	case 2:
+		callHandlers(2)
+	case 3:
+		callHandlers(3)
+	case 4:
+		callHandlers(4)
+	case 5:
+		callHandlers(5)
+	case 6:
+		callHandlers(6)
+	case 7:
+		callHandlers(7)
+	case 8:
+		callHandlers(8)
+	case 9:
+		callHandlers(9)
+	case 10:
+		callHandlers(10)
+	case 11:
+		callHandlers(11)
+	case 12:
+		callHandlers(12)
+	case 13:
+		callHandlers(13)
+	case 14:
+		callHandlers(14)
+	case 15:
+		callHandlers(15)
+	case 16:
+		callHandlers(16)
+	case 17:
+		callHandlers(17)
+	case 18:
+		callHandlers(18)
+	case 19:
+		callHandlers(19)
+	case 20:
+		callHandlers(20)
+	case 21:
+		callHandlers(21)
+	case 22:
+		callHandlers(22)
+	case 23:
+		callHandlers(23)
+	case 24:
+		callHandlers(24)
+	case 25:
+		callHandlers(25)
+	case 26:
+		callHandlers(26)
+	case 27:
+		callHandlers(27)
+	case 28:
+		callHandlers(28)
+	case 29:
+		callHandlers(29)
+	case 30:
+		callHandlers(30)
+	case 31:
+		callHandlers(31)
+	case 32:
+		callHandlers(32)
+	case 33:
+		callHandlers(33)
+	case 34:
+		callHandlers(34)
+	case 35:
+		callHandlers(35)
+	case 36:
+		callHandlers(36)
+	case 37:
+		callHandlers(37)
+	case 38:
+		callHandlers(38)
+	case 39:
+		callHandlers(39)
+	case 40:
+		callHandlers(40)
+	case 41:
+		callHandlers(41)
+	case 42:
+		callHandlers(42)
+	case 43:
+		callHandlers(43)
+	case 44:
+		callHandlers(44)
+	case 45:
+		callHandlers(45)
+	}
+}
+
+//export handleInterrupt
+func handleInterrupt() {
+	cause := riscv.MCAUSE.Get()
+	if cause&(uintptr(1)<<31) == 0 || cause&0x7fffffff != riscv.MachineExternalInterrupt {
+		for {
+			riscv.Asm("wfi")
+		}
+	}
+
+	// Save external-interrupt context and clear the standard timer/software
+	// enables just as the Pico SDK Hazard3 entry path does.
+	context := hazard3MEICONTEXT.SetBits(2)
+	for {
+		next := hazard3MEINEXT.SetBits(1)
+		if next&(uintptr(1)<<31) != 0 {
+			break
+		}
+		callHandler(int((next & 0x7fc) >> 2))
+	}
+	hazard3MEICONTEXT.Set(context)
+	riscv.MCAUSE.Set(0)
+}
