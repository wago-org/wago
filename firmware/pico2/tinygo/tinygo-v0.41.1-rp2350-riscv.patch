diff --git a/src/machine/machine_rp2350_irq_arm.go b/src/machine/machine_rp2350_irq_arm.go
new file mode 100644
index 0000000..5ced671
--- /dev/null
+++ b/src/machine/machine_rp2350_irq_arm.go
@@ -0,0 +1,27 @@
+//go:build rp2350 && !pico2riscv
+
+package machine
+
+import "device/rp"
+
+func rp2350IRQSet(num uint32, enabled bool) {
+	if num >= _NUMIRQ {
+		return
+	}
+
+	registerIndex := num / 32
+	mask := uint32(1) << (num % 32)
+	if enabled {
+		if registerIndex == 0 {
+			rp.PPB.NVIC_ICPR0.Set(mask)
+			rp.PPB.NVIC_ISER0.Set(mask)
+		} else {
+			rp.PPB.NVIC_ICPR1.Set(mask)
+			rp.PPB.NVIC_ISER1.Set(mask)
+		}
+	} else if registerIndex == 0 {
+		rp.PPB.NVIC_ICER0.Set(mask)
+	} else {
+		rp.PPB.NVIC_ICER1.Set(mask)
+	}
+}
diff --git a/src/machine/machine_rp2350_irq_hazard3.go b/src/machine/machine_rp2350_irq_hazard3.go
new file mode 100644
index 0000000..71fbc89
--- /dev/null
+++ b/src/machine/machine_rp2350_irq_hazard3.go
@@ -0,0 +1,28 @@
+//go:build rp2350 && pico2riscv
+
+package machine
+
+import "device/riscv"
+
+const (
+	hazard3MEIEA = riscv.CSR(0xbe0)
+	hazard3MEIFA = riscv.CSR(0xbe2)
+)
+
+func rp2350IRQSet(num uint32, enabled bool) {
+	if num >= _NUMIRQ {
+		return
+	}
+
+	window := uintptr(num / 16)
+	mask := uintptr(1) << (num % 16)
+	selectorAndMask := window | mask<<16
+	if enabled {
+		// Clear a forced pending bit before enabling. An asserted peripheral
+		// immediately becomes pending again.
+		hazard3MEIFA.ClearBits(selectorAndMask)
+		hazard3MEIEA.SetBits(selectorAndMask)
+	} else {
+		hazard3MEIEA.ClearBits(selectorAndMask)
+	}
+}
