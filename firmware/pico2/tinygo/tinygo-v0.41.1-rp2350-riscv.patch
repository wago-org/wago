index 0000000..a25e321
--- /dev/null
+++ b/src/runtime/runtime_rp2350_hazard3.go
@@ -0,0 +1,47 @@
+//go:build rp2350 && pico2riscv
+
+package runtime
+
+import (
+	"device/riscv"
+	"unsafe"
+)
+
+//go:extern handleInterruptASM
+var handleInterruptASM [0]uintptr
+
+func rp2InitInterrupts() {
+	riscv.MCAUSE.Set(0)
+	riscv.MTVEC.Set(uintptr(unsafe.Pointer(&handleInterruptASM)))
+	// The boot ROM does not promise that Hazard3's banked external-enable
+	// array is clear. Disable every RP2350 IRQ before drivers register theirs.
+	for window := uintptr(0); window < 3; window++ {
+		riscv.CSR(0xbe0).ClearBits(window | uintptr(0xffff)<<16)
+	}
+	riscv.MIE.Set(riscv.MIE_MEIE)
+	riscv.MSTATUS.ClearBits(riscv.MSTATUS_MIE)
+}
+
+func rp2EnableInterrupts() {
+	riscv.MSTATUS.SetBits(riscv.MSTATUS_MIE)
+}
+
+func rp2WaitForEvent() {
+	riscv.Asm("wfi")
+}
+
+// The Pico 2 RISC-V target currently runs a single core without the task
+// scheduler. There is therefore no sleeping peer hart to notify.
+func rp2SendEvent() {
+	riscv.Asm("fence rw, rw")
+}
+
+func exit(code int) {
+	for {
+		riscv.Asm("wfi")
+	}
+}
+
+func abort() {
+	exit(1)
+}
