;; Test store cmp result to mem

(module
  (func (export "eq") (param $x f32) (param $y f32) (result i32) 
    (local i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32)
    (local $l1 i32)
    local.get $x
    local.get $y
    f32.eq
    local.tee $l1
  )

  (func (export "ne") (param $x f32) (param $y f32) (result i32) 
    (local i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32)
    (local $l1 i32)
    local.get $x
    local.get $y
    f32.ne
    local.tee $l1
  )

  (func (export "gt") (param $x f32) (param $y f32) (result i32) 
    (local i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32)
    (local $l1 i32)
    local.get $x
    local.get $y
    f32.gt
    local.tee $l1
  )

  (func (export "ge") (param $x f32) (param $y f32) (result i32) 
    (local i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32)
    (local $l1 i32)
    local.get $x
    local.get $y
    f32.ge
    local.tee $l1
  )
    (func (export "lt") (param $x f32) (param $y f32) (result i32) 
    (local i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32)
    (local $l1 i32)
    local.get $x
    local.get $y
    f32.lt
    local.tee $l1
  )
  (func (export "le") (param $x f32) (param $y f32) (result i32) 
    (local i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32 i32)
    (local $l1 i32)
    local.get $x
    local.get $y
    f32.le
    local.tee $l1
  )
 
)


(assert_return (invoke "eq" (f32.const -0x0p+0) (f32.const -0x0p+0)) (i32.const 1))
(assert_return (invoke "eq" (f32.const -0x0p+0) (f32.const 0x0p+0)) (i32.const 1))
